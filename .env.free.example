# Free-tier / test profile env. Copy to .env.free and edit:
#   cp .env.free.example .env.free
#   docker compose -f docker-compose.free.yml --env-file .env.free up -d
#
# Everything has a working default in docker-compose.free.yml, so the ONLY thing
# you must set for a real test is a shared secret the backend also uses.

# Shared secret the backend sends as the X-AI-Secret header (REQUIRED).
API_SECRET_KEY=change-me-to-a-long-random-string

# Where the AI service POSTs async results, and the secret it signs them with.
FASTIFY_CALLBACK_URL=http://your-backend:3000/internal/ai-callback
FASTIFY_CALLBACK_SECRET=change-me-too

# --- optional knobs (sane defaults already in the compose file) ---
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
# POSTGRES_USER=healthai
# POSTGRES_PASSWORD=healthai
# API_WORKERS=2
# WORKER_CONCURRENCY=2

# Whisper: base is small/fast on CPU. Use large-v3 only with a real GPU.
WHISPER_MODEL_SIZE=base

# LLM is OPTIONAL. Leave the default and generative features degrade gracefully.
# To enable them, run Ollama/vLLM somewhere and point at it (OpenAI-compatible):
#   LLM_BASE_URL=http://your-llm-host:11434/v1
#   LLM_MODEL=granite4.1:8b
